# Get a FREE key (no credit card required) from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Server
PORT=5000

# Free-tier model used for question generation & evaluation.
# llama-3.3-70b-versatile: best quality, 1,000 requests/day free.
# llama-3.1-8b-instant: lower quality but 14,400 requests/day free — use this if you're rate limited a lot.
GROQ_MODEL=llama-3.3-70b-versatile
